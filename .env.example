# Copy this file to `.env.local` and fill in your Apple Developer credentials.
# `.env.local` is gitignored — don't commit it.
#
# Used by `scripts/release-mac.sh` to produce a signed + notarized DMG.

# The exact name of your Developer ID Application certificate as it appears in
# Keychain Access. Looks like: "Developer ID Application: Your Name (ABCD123456)"
# Find it with:
#   security find-identity -p codesigning -v
APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (ABCD123456)"

# Your Apple ID email.
APPLE_ID="you@example.com"

# An app-specific password (NOT your real Apple ID password).
# Create one at https://appleid.apple.com → Sign-In and Security → App-Specific Passwords.
APPLE_PASSWORD="abcd-efgh-ijkl-mnop"

# Your 10-character Apple Developer Team ID.
# Find it at https://developer.apple.com → Membership.
APPLE_TEAM_ID="ABCD123456"
